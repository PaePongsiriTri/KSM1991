/**
 * Cloudflare Workers config — serves the Next.js static export from ./out
 * directly via Workers Assets, no OpenNext / SSR / SQLite cache involved.
 *
 * Docs: https://developers.cloudflare.com/workers/static-assets/
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ksm1991",
  "compatibility_date": "2025-03-01",
  "assets": {
    "directory": "./out",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  }
}
